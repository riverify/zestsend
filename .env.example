# ZestSend Environment Configuration
# Copy this file to .env.production and update values

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Redis connection URL with authentication
REDIS_URL=redis://:zestsend_secure_redis_2026@zestsend-redis:6379

# Redis password (change this in production!)
REDIS_PASSWORD=zestsend_secure_redis_2026

# -----------------------------------------------------------------------------
# Next.js Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Application port (internal, don't change)
PORT=3000

# -----------------------------------------------------------------------------
# Optional: TURN Server Configuration (for better NAT traversal)
# -----------------------------------------------------------------------------
# If you experience connection issues, set up a TURN server:
# https://github.com/coturn/coturn
#
# TURN_SERVER=turn:your-domain.com:3478
# TURN_USERNAME=zestsend_user
# TURN_PASSWORD=your_secure_turn_password

# -----------------------------------------------------------------------------
# Security (Optional)
# -----------------------------------------------------------------------------
# Rate limiting (requests per minute per IP)
# RATE_LIMIT=100

# Allowed origins (comma-separated, for CORS)
# ALLOWED_ORIGINS=https://your-domain.com
